# API
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/closiq_discord_agent

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=closiq_knowledgebase

# AI provider
# Leave empty to use the local deterministic fallback for scaffolding/dev.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Discord bot
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
# Optional: if set, the bot only auto-replies in this channel.
DISCORD_SUPPORT_CHANNEL_ID=
AUTO_REPLY_ENABLED=true

# Web
VITE_API_BASE_URL=http://localhost:4000/api
