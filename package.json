{
  "name": "closiq-discord-agent",
  "version": "0.1.0",
  "private": true,
  "description": "A modular monolith Discord support inbox with AI-assisted replies backed by MongoDB and Qdrant.",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm --workspace @closiq-discord-agent/api run dev",
    "dev:web": "npm --workspace @closiq-discord-agent/web run dev",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
